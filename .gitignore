# =============================================================================
# OpenClaw News Monitor — .gitignore
# =============================================================================

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db

# ── Linux / Editor ────────────────────────────────────────────────────────────
*~
.idea/
.vscode/
*.swp
*.swo
*.kate-swp

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm
.pnp
.pnp.js

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
htmlcov/
*.mo
*.pot
*.pyc
venv/
env/
ENV/
.env/
.venv/

# ── Secrets / Credentials ─────────────────────────────────────────────────────
.env
.env.*
*.env
*.pem
*.key
*.cert
*.crt
secrets/
credentials/
config/secrets.json
config/secrets.yaml
config/secrets.yml
.secret
.secrets

# ── Logs / Temporary ──────────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
.tmp/
*.tmp
*.bak
*.orig

# ── OpenClaw local workspace (managed by sync script, not committed) ──────────
# Uncomment below if you do NOT want to commit workspace overrides
# ~/.openclaw/

# ── OS / Archive ──────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z
